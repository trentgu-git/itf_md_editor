<Window x:Class="ITforceMarkdown.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ITforceMarkdown.Views"
        Title="ITforce Markdown"
        Width="1240"
        Height="760"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.Window}"
        AllowDrop="True"
        Drop="MainWindow_Drop"
        Icon="{x:Null}"><!-- 真正的图标在 code-behind 按 Local/Pro flavor 设, 这里仅占位 -->

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewDocCommand}"/>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Key="OemOpenBrackets" Modifiers="Control" Command="{Binding BackCommand}"/>
        <KeyBinding Key="OemCloseBrackets" Modifiers="Control" Command="{Binding ForwardCommand}"/>
        <KeyBinding Key="OemBackslash" Modifiers="Control" Command="{Binding ToggleSidebarCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- 顶部菜单 -->
        <Menu DockPanel.Dock="Top"
              Background="{DynamicResource Brush.ToolbarBg}">
            <MenuItem x:Name="MenuFile" Header="_File">
                <MenuItem x:Name="MenuNew"        Header="_New"           InputGestureText="Ctrl+N" Click="MenuNew_Click"/>
                <MenuItem x:Name="MenuOpenFile"   Header="_Open File…"    InputGestureText="Ctrl+O" Click="MenuOpenFile_Click"/>
                <MenuItem x:Name="MenuOpenFolder" Header="Open _Folder…"  Click="MenuOpenFolder_Click"/>
                <MenuItem x:Name="MenuRecent"     Header="Open _Recent"/>
                <Separator/>
                <MenuItem x:Name="MenuSave"       Header="_Save"          InputGestureText="Ctrl+S" Click="MenuSave_Click"/>
                <MenuItem x:Name="MenuClose"      Header="_Close Document" Click="MenuClose_Click"/>
                <Separator x:Name="MenuGitLabSep1" Visibility="Collapsed"/>
                <!-- Pro only: GitLab 子菜单, code-behind 按 flavor 显示 -->
                <MenuItem x:Name="MenuGitLab" Header="_GitLab" Visibility="Collapsed">
                    <MenuItem x:Name="MenuGitLabSettings" Header="GitLab _Settings…" Click="MenuGitLabSettings_Click"/>
                    <MenuItem x:Name="MenuGitLabSync" Header="Sync _Now" Click="MenuGitLabSync_Click"/>
                </MenuItem>
                <Separator/>
                <MenuItem x:Name="MenuExportPdf"  Header="Export _PDF…"   Click="MenuExportPdf_Click"/>
                <MenuItem x:Name="MenuExportWord" Header="Export _Word…"  Click="MenuExportWord_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuExit"       Header="E_xit"          Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem x:Name="MenuEdit" Header="_Edit">
                <MenuItem x:Name="MenuEditUndo"   Command="ApplicationCommands.Undo"/>
                <MenuItem x:Name="MenuEditRedo"   Command="ApplicationCommands.Redo"/>
                <Separator/>
                <MenuItem x:Name="MenuEditCut"    Command="ApplicationCommands.Cut"/>
                <MenuItem x:Name="MenuEditCopy"   Command="ApplicationCommands.Copy"/>
                <MenuItem x:Name="MenuEditPaste"  Command="ApplicationCommands.Paste"/>
                <Separator/>
                <MenuItem x:Name="MenuEditSelectAll" Command="ApplicationCommands.SelectAll"/>
            </MenuItem>
            <MenuItem x:Name="MenuView" Header="_View">
                <MenuItem x:Name="MenuModeRead"   Header="_Read"   Click="MenuModeRead_Click"/>
                <MenuItem x:Name="MenuModeRich"   Header="_Edit"   Click="MenuModeRich_Click"/>
                <MenuItem x:Name="MenuModeSource" Header="_Source" Click="MenuModeSource_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuAppearance" Header="_Appearance">
                    <MenuItem x:Name="MenuApSystem" Header="Follow System" Click="MenuApSystem_Click" IsCheckable="True"/>
                    <MenuItem x:Name="MenuApLight"  Header="Light"  Click="MenuApLight_Click"  IsCheckable="True"/>
                    <MenuItem x:Name="MenuApDark"   Header="Dark"   Click="MenuApDark_Click"   IsCheckable="True"/>
                </MenuItem>
                <!-- 语言切换 — code-behind 按 store.MenuLanguage 设 IsChecked -->
                <MenuItem x:Name="MenuLanguage" Header="_Language">
                    <MenuItem x:Name="MenuLangSystem"  Header="Follow System / 跟随系统" Click="MenuLangSystem_Click"  IsCheckable="True"/>
                    <MenuItem x:Name="MenuLangEnglish" Header="English"                  Click="MenuLangEnglish_Click" IsCheckable="True"/>
                    <MenuItem x:Name="MenuLangChinese" Header="中文"                     Click="MenuLangChinese_Click" IsCheckable="True"/>
                </MenuItem>
                <Separator/>
                <MenuItem x:Name="MenuToggleSidebar" Header="Toggle _Sidebar" InputGestureText="Ctrl+\" Click="MenuToggleSidebar_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuBack"    Header="_Back"    InputGestureText="Ctrl+[" Click="MenuBack_Click"/>
                <MenuItem x:Name="MenuForward" Header="_Forward" InputGestureText="Ctrl+]" Click="MenuForward_Click"/>
            </MenuItem>
            <MenuItem x:Name="MenuWindow" Header="_Window">
                <MenuItem x:Name="MenuWindowMin"        Header="_Minimize"          Click="MenuMinimize_Click"/>
                <MenuItem x:Name="MenuWindowMaxRestore" Header="_Maximize / Restore" Click="MenuMaxRestore_Click"/>
            </MenuItem>
            <MenuItem x:Name="MenuHelp" Header="_Help">
                <MenuItem x:Name="MenuHelpDocs"  Header="ITforce Markdown _Help" Click="MenuHelp_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuHelpAbout" Header="_About" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <!-- 状态栏 -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource Brush.ToolbarBg}"
                BorderBrush="{DynamicResource Brush.Line}"
                BorderThickness="0,1,0,0"
                Padding="12,4">
            <TextBlock x:Name="StatusBar"
                       Text="Ready"
                       FontSize="11"
                       Foreground="{DynamicResource Brush.Muted}"/>
        </Border>

        <!-- 主区: sidebar 左, 右侧 TopActionBar + DocumentWorkspace -->
        <Grid x:Name="RootGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarCol" Width="280" MinWidth="200"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*" MinWidth="500"/>
            </Grid.ColumnDefinitions>

            <views:Sidebar Grid.Column="0"/>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource Brush.Line}"
                          ResizeBehavior="PreviousAndNext"/>

            <DockPanel Grid.Column="2">
                <views:TopActionBar DockPanel.Dock="Top"/>
                <views:DocumentWorkspace/>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
