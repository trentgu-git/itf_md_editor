<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== 颜色 (复刻 Mac 版 AppTheme.light) ===== -->
    <Color x:Key="Color.Accent">#F59B14</Color>
    <Color x:Key="Color.Window">#F5F5F7</Color>
    <Color x:Key="Color.Card">#FFFFFF</Color>
    <Color x:Key="Color.Sidebar">#FAF7F0</Color>
    <Color x:Key="Color.SidebarSectionActive">#FCEFD4</Color>
    <Color x:Key="Color.SidebarSectionInactive">#F2EFE8</Color>
    <Color x:Key="Color.SelectedFile">#FFF0D1</Color>
    <Color x:Key="Color.OutlineBg">#F7F7FA</Color>
    <Color x:Key="Color.EditorBg">#F5F5F7</Color>
    <Color x:Key="Color.Ink">#1C2433</Color>
    <Color x:Key="Color.Muted">#6B7585</Color>
    <Color x:Key="Color.Placeholder">#8C8C8C</Color>
    <Color x:Key="Color.FolderText">#3C5473</Color>
    <Color x:Key="Color.FolderIcon">#D16E2E</Color>
    <Color x:Key="Color.ToolbarIcon">#484D54</Color>
    <Color x:Key="Color.Line">#E0D7C2</Color>
    <Color x:Key="Color.SelectionInk">#5C3608</Color>
    <Color x:Key="Color.ToolbarBg">#FFFFFF</Color>
    <Color x:Key="Color.Toast">#1C2433</Color>

    <!-- 注: SolidColorBrushes 只在 App.xaml 里出现一次, 这两份字典纯靠 Color 提供; 见 App.xaml -->
</ResourceDictionary>
