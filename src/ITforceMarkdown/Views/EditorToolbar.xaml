<UserControl x:Class="ITforceMarkdown.Views.EditorToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ⚠️ Resources 必须在使用之前 (WPF StaticResource 硬性要求). -->
    <UserControl.Resources>
        <Style x:Key="FmtButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Line}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.ToolbarIcon}"/>
            <Setter Property="MinWidth" Value="34"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource Brush.SidebarSectionInactive}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DividerLine" TargetType="Border">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Margin" Value="6,6,6,6"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Line}"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource Brush.ToolbarBg}"
            BorderBrush="{DynamicResource Brush.Line}"
            BorderThickness="0,0,0,1"
            Padding="10,4">
        <StackPanel Orientation="Horizontal">
            <!-- Headings -->
            <Button Style="{StaticResource FmtButton}" ToolTip="Heading 1" Click="H1_Click">
                <TextBlock Text="H1" FontWeight="Bold"/>
            </Button>
            <Button Style="{StaticResource FmtButton}" ToolTip="Heading 2" Click="H2_Click">
                <TextBlock Text="H2" FontWeight="Bold"/>
            </Button>
            <Button Style="{StaticResource FmtButton}" ToolTip="Heading 3" Click="H3_Click">
                <TextBlock Text="H3" FontWeight="Bold"/>
            </Button>
            <Button Style="{StaticResource FmtButton}" ToolTip="Paragraph" Click="P_Click">
                <TextBlock Text="¶"/>
            </Button>

            <Border Style="{StaticResource DividerLine}"/>

            <!-- Inline -->
            <Button Style="{StaticResource FmtButton}" ToolTip="Bold (Ctrl+B)" Click="Bold_Click">
                <TextBlock Text="B" FontWeight="Bold"/>
            </Button>
            <Button Style="{StaticResource FmtButton}" ToolTip="Italic (Ctrl+I)" Click="Italic_Click">
                <TextBlock Text="I" FontStyle="Italic"/>
            </Button>
            <Button Style="{StaticResource FmtButton}" ToolTip="Strikethrough" Click="Strike_Click">
                <TextBlock Text="S" TextDecorations="Strikethrough"/>
            </Button>
            <Button Style="{StaticResource FmtButton}" ToolTip="Inline code" Click="InlineCode_Click">
                <TextBlock Text="‹/›" FontFamily="Cascadia Code, Consolas, monospace"/>
            </Button>

            <Border Style="{StaticResource DividerLine}"/>

            <!-- Lists / Blocks -->
            <Button Style="{StaticResource FmtButton}" ToolTip="Bullet list" Click="UL_Click">
                <TextBlock Text="• ─"/>
            </Button>
            <Button Style="{StaticResource FmtButton}" ToolTip="Numbered list" Click="OL_Click">
                <TextBlock Text="1. ─"/>
            </Button>
            <Button Style="{StaticResource FmtButton}" ToolTip="Quote" Click="Quote_Click">
                <TextBlock Text="❝"/>
            </Button>
            <Button Style="{StaticResource FmtButton}" ToolTip="Code block" Click="CodeBlock_Click">
                <!-- {}{ } : 前导 {} 是 XAML 的 "literal-text" 转义, 否则 {} 会被
                     当成 markup extension (类似 {Binding}) 解析, MC3074 报错 -->
                <TextBlock Text="{}{ }" FontFamily="Cascadia Code, Consolas, monospace"/>
            </Button>

            <Border Style="{StaticResource DividerLine}"/>

            <!-- Insert -->
            <Button Style="{StaticResource FmtButton}" ToolTip="Insert link" Click="Link_Click">
                <TextBlock Text="🔗"/>
            </Button>
            <Button Style="{StaticResource FmtButton}" ToolTip="Insert image" Click="Image_Click">
                <TextBlock Text="🖼"/>
            </Button>
            <Button Style="{StaticResource FmtButton}" ToolTip="Insert table" Click="Table_Click">
                <TextBlock Text="▦"/>
            </Button>
            <Button Style="{StaticResource FmtButton}" ToolTip="Horizontal rule" Click="HR_Click">
                <TextBlock Text="—"/>
            </Button>
        </StackPanel>
    </Border>
</UserControl>
