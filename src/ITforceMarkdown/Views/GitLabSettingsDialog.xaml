<Window x:Class="ITforceMarkdown.Views.GitLabSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GitLab Sync — Settings"
        Width="560"
        Height="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource Brush.Window}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="Sync a GitLab project to a local cache"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.Ink}"/>
        <TextBlock Grid.Row="1"
                   Text="Configure once, then click Sync Now to clone or pull. The local cache folder becomes a workspace in the sidebar."
                   FontSize="12"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource Brush.Muted}"
                   Margin="0,4,0,16"/>

        <!-- Project URL -->
        <TextBlock Grid.Row="2" Text="Project URL" Foreground="{DynamicResource Brush.Ink}" Margin="0,0,0,4"/>
        <TextBox Grid.Row="3"
                 x:Name="UrlBox"
                 Padding="8,6"
                 FontSize="12"
                 Foreground="{DynamicResource Brush.Ink}"
                 Background="{DynamicResource Brush.Card}"
                 BorderBrush="{DynamicResource Brush.Line}"
                 Margin="0,0,0,12"/>

        <!-- Token + Username -->
        <Grid Grid.Row="4" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Access Token (PAT)" Foreground="{DynamicResource Brush.Ink}"/>
            <TextBlock Grid.Column="1" Text="Username" Foreground="{DynamicResource Brush.Ink}" Margin="8,0,0,0"/>
        </Grid>
        <Grid Grid.Row="5" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>
            <PasswordBox x:Name="TokenBox"
                         Padding="8,6"
                         FontSize="12"
                         Foreground="{DynamicResource Brush.Ink}"
                         Background="{DynamicResource Brush.Card}"
                         BorderBrush="{DynamicResource Brush.Line}"/>
            <TextBox Grid.Column="1"
                     x:Name="UserBox"
                     Padding="8,6"
                     FontSize="12"
                     Foreground="{DynamicResource Brush.Ink}"
                     Background="{DynamicResource Brush.Card}"
                     BorderBrush="{DynamicResource Brush.Line}"
                     Margin="8,0,0,0"/>
        </Grid>

        <!-- Cache folder -->
        <TextBlock Grid.Row="6" Text="Local cache folder" Foreground="{DynamicResource Brush.Ink}" Margin="0,0,0,4"/>
        <Grid Grid.Row="7" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="FolderBox"
                     Padding="8,6"
                     FontSize="12"
                     Foreground="{DynamicResource Brush.Ink}"
                     Background="{DynamicResource Brush.Card}"
                     BorderBrush="{DynamicResource Brush.Line}"/>
            <Button Grid.Column="1"
                    Content="Browse…"
                    Padding="12,4"
                    Margin="8,0,0,0"
                    Click="Browse_Click"/>
        </Grid>

        <!-- Status -->
        <Border Grid.Row="8"
                Background="{DynamicResource Brush.Card}"
                BorderBrush="{DynamicResource Brush.Line}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12"
                Margin="0,8,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="StatusText"
                           Text="Configure the fields above and click Sync Now."
                           FontSize="11"
                           Foreground="{DynamicResource Brush.Muted}"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="9"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="BtnSync"
                    Content="Sync Now"
                    Padding="14,6"
                    MinWidth="100"
                    Click="Sync_Click"/>
            <Button x:Name="BtnSave"
                    Content="Save"
                    Padding="14,6"
                    MinWidth="80"
                    Margin="8,0,0,0"
                    Click="Save_Click"
                    IsDefault="True"/>
            <Button Content="Cancel"
                    Padding="14,6"
                    MinWidth="80"
                    Margin="8,0,0,0"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
