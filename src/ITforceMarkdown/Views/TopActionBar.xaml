<UserControl x:Class="ITforceMarkdown.Views.TopActionBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{DynamicResource Brush.ToolbarBg}"
            BorderBrush="{DynamicResource Brush.Line}"
            BorderThickness="0,0,0,1"
            Height="56">
        <DockPanel LastChildFill="True">

            <!-- 右侧三个工具按钮 -->
            <StackPanel Orientation="Horizontal"
                        DockPanel.Dock="Right"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center">
                <Button x:Name="BtnOpenFolder"
                        Style="{StaticResource ToolbarButton}"
                        Click="OpenFolder_Click"
                        ToolTip="Add a workspace folder">
                    <StackPanel>
                        <TextBlock Text="📁+" HorizontalAlignment="Center" FontSize="16"/>
                        <TextBlock Text="Open Folder" HorizontalAlignment="Center" FontSize="10" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnOpenFile"
                        Style="{StaticResource ToolbarButton}"
                        Click="OpenFile_Click"
                        ToolTip="Open a Markdown file">
                    <StackPanel>
                        <TextBlock Text="📄" HorizontalAlignment="Center" FontSize="16"/>
                        <TextBlock Text="Open File" HorizontalAlignment="Center" FontSize="10" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnNewFile"
                        Style="{StaticResource ToolbarButton}"
                        Click="NewFile_Click"
                        ToolTip="Create new Markdown file">
                    <StackPanel>
                        <TextBlock Text="✏️" HorizontalAlignment="Center" FontSize="16"/>
                        <TextBlock Text="New File" HorizontalAlignment="Center" FontSize="10" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- 左侧 App 标题 -->
            <TextBlock Text="ITFORCE MARKDOWN EDITOR"
                       FontSize="13"
                       FontWeight="Bold"
                       Foreground="{DynamicResource Brush.ToolbarIcon}"
                       VerticalAlignment="Center"
                       Margin="20,0,0,0"/>
        </DockPanel>
    </Border>

    <UserControl.Resources>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.ToolbarIcon}"/>
            <Setter Property="Width" Value="72"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Brush.SidebarSectionInactive}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
</UserControl>
