<UserControl x:Class="ITforceMarkdown.Views.Outline"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{DynamicResource Brush.OutlineBg}"
            BorderBrush="{DynamicResource Brush.Line}"
            BorderThickness="0,0,1,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 标题 -->
                <RowDefinition Height="Auto"/>  <!-- Filter 框 -->
                <RowDefinition Height="*"/>     <!-- Heading 列表 -->
            </Grid.RowDefinitions>

            <!-- "OUTLINE" 标题 -->
            <Border Grid.Row="0" Padding="16,16,16,8">
                <TextBlock Text="OUTLINE"
                           FontSize="10"
                           FontWeight="Bold"
                           Foreground="{DynamicResource Brush.Muted}"
                           Opacity="0.7"/>
            </Border>

            <!-- Filter -->
            <Border Grid.Row="1" Padding="12,4,12,8">
                <Grid>
                    <TextBox x:Name="FilterBox"
                             Padding="22,6,6,6"
                             FontSize="11"
                             Background="{DynamicResource Brush.Card}"
                             BorderBrush="{DynamicResource Brush.Line}"
                             Foreground="{DynamicResource Brush.Ink}"
                             TextChanged="FilterBox_TextChanged"/>
                    <TextBlock Text="🔍 Filter"
                               IsHitTestVisible="False"
                               Padding="8,8,0,0"
                               Foreground="{DynamicResource Brush.Placeholder}"
                               FontSize="10"
                               x:Name="FilterPlaceholder"/>
                </Grid>
            </Border>

            <!-- Heading 列表 -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,0,0,12">
                <StackPanel x:Name="HeadingsHost"/>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
