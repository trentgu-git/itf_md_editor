<UserControl x:Class="ITforceMarkdown.Views.DocumentWorkspace"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ITforceMarkdown.Views">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 文档头 (标题 + Save + Export + Mode switch) -->
            <RowDefinition Height="*"/>     <!-- 内容 -->
        </Grid.RowDefinitions>

        <!-- 文档头 -->
        <Border Grid.Row="0"
                Background="{DynamicResource Brush.Card}"
                BorderBrush="{DynamicResource Brush.Line}"
                BorderThickness="0,0,0,1"
                Padding="20,10">
            <DockPanel>
                <!-- 右侧: Mode 切换 + Save + Export PDF/Word + Close -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button x:Name="BtnRead" Content="Read"
                            Style="{StaticResource ModeButton}"
                            Click="ModeRead_Click"/>
                    <Button x:Name="BtnRich" Content="Edit"
                            Style="{StaticResource ModeButton}"
                            Click="ModeRich_Click"/>
                    <Button x:Name="BtnSource" Content="Source"
                            Style="{StaticResource ModeButton}"
                            Click="ModeSource_Click"/>

                    <Border Width="1" Margin="8,4" Background="{DynamicResource Brush.Line}"/>

                    <Button x:Name="BtnSave" Content="Save"
                            Style="{StaticResource ActionButton}"
                            Click="Save_Click"/>
                    <Button x:Name="BtnExportPdf" Content="PDF"
                            Style="{StaticResource ActionButton}"
                            Click="ExportPdf_Click"/>
                    <Button x:Name="BtnExportWord" Content="Word"
                            Style="{StaticResource ActionButton}"
                            Click="ExportWord_Click"/>
                    <Button x:Name="BtnClose" Content="×"
                            Style="{StaticResource ActionButton}"
                            Click="Close_Click"
                            FontSize="16"/>
                </StackPanel>

                <!-- 左侧: 文档标题 (含 dirty 圆点) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="DirtyDot" Width="8" Height="8"
                             Fill="{DynamicResource Brush.Accent}"
                             Margin="0,0,8,0"
                             Visibility="Collapsed"/>
                    <TextBlock x:Name="TitleLabel"
                               Text="No document"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.Ink}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 内容: 根据 Store.EditorMode 切换 -->
        <Grid Grid.Row="1" x:Name="ContentHost"/>

    </Grid>

    <UserControl.Resources>
        <Style x:Key="ModeButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Muted}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.ToolbarIcon}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinWidth" Value="40"/>
        </Style>
    </UserControl.Resources>
</UserControl>
