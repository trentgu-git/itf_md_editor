<UserControl x:Class="ITforceMarkdown.Views.DocumentWorkspace"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ITforceMarkdown.Views">

    <!-- ⚠️ Resources 必须在使用之前。同 TopActionBar.xaml 的修复理由。 -->
    <UserControl.Resources>
        <Style x:Key="ModeButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Muted}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.ToolbarIcon}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinWidth" Value="40"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 文档头 (标题 + Save + Export + Mode switch) -->
            <RowDefinition Height="*"/>     <!-- 内容 -->
        </Grid.RowDefinitions>

        <!-- 文档头 -->
        <Border Grid.Row="0"
                Background="{DynamicResource Brush.Card}"
                BorderBrush="{DynamicResource Brush.Line}"
                BorderThickness="0,0,0,1"
                Padding="20,10">
            <DockPanel>
                <!-- 右侧: Find + Zoom + Mode + Reload/Delete/Clone/Fullscreen + Save + Export + Close -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <!-- Find: 简单输入框 + Ctrl+F (WebView2 原生 Find 也走这条路) -->
                    <Button x:Name="BtnFind"
                            Style="{StaticResource ActionButton}"
                            Click="Find_Click"
                            ToolTip="Find in document (Ctrl+F)">
                        <TextBlock Text="🔍" FontSize="12"/>
                    </Button>

                    <Border Width="1" Margin="8,4" Background="{DynamicResource Brush.Line}"/>

                    <!-- Zoom 控件: −  100%  + -->
                    <Button x:Name="BtnZoomOut"
                            Style="{StaticResource ActionButton}"
                            Click="ZoomOut_Click"
                            ToolTip="Zoom out (Ctrl-)">
                        <TextBlock Text="−" FontSize="14" FontWeight="Bold"/>
                    </Button>
                    <Button x:Name="BtnZoomReset"
                            Style="{StaticResource ActionButton}"
                            Click="ZoomReset_Click"
                            ToolTip="Reset zoom (Ctrl+0)">
                        <TextBlock x:Name="ZoomLabel" Text="100%" FontSize="11"/>
                    </Button>
                    <Button x:Name="BtnZoomIn"
                            Style="{StaticResource ActionButton}"
                            Click="ZoomIn_Click"
                            ToolTip="Zoom in (Ctrl+=)">
                        <TextBlock Text="+" FontSize="14" FontWeight="Bold"/>
                    </Button>

                    <Border Width="1" Margin="8,4" Background="{DynamicResource Brush.Line}"/>

                    <Button x:Name="BtnRead" Content="Read"
                            Style="{StaticResource ModeButton}"
                            Click="ModeRead_Click"/>
                    <Button x:Name="BtnRich" Content="Edit"
                            Style="{StaticResource ModeButton}"
                            Click="ModeRich_Click"/>
                    <Button x:Name="BtnSource" Content="Source"
                            Style="{StaticResource ModeButton}"
                            Click="ModeSource_Click"/>

                    <Border Width="1" Margin="8,4" Background="{DynamicResource Brush.Line}"/>

                    <Button x:Name="BtnReload"
                            Style="{StaticResource ActionButton}"
                            Click="Reload_Click"
                            ToolTip="Reload from disk (discard unsaved if any)">
                        <TextBlock Text="↻" FontSize="14"/>
                    </Button>
                    <Button x:Name="BtnDelete"
                            Style="{StaticResource ActionButton}"
                            Click="Delete_Click"
                            ToolTip="Move to Recycle Bin">
                        <TextBlock Text="🗑" FontSize="13"/>
                    </Button>
                    <Button x:Name="BtnDuplicate"
                            Style="{StaticResource ActionButton}"
                            Click="Duplicate_Click"
                            ToolTip="Duplicate this document">
                        <TextBlock Text="⧉" FontSize="14"/>
                    </Button>
                    <Button x:Name="BtnFullscreen"
                            Style="{StaticResource ActionButton}"
                            Click="Fullscreen_Click"
                            ToolTip="Toggle distraction-free mode (Ctrl+\)">
                        <TextBlock x:Name="FullscreenIcon" Text="⛶" FontSize="14"/>
                    </Button>

                    <Border Width="1" Margin="8,4" Background="{DynamicResource Brush.Line}"/>

                    <Button x:Name="BtnSave" Content="Save"
                            Style="{StaticResource ActionButton}"
                            Click="Save_Click"/>
                    <Button x:Name="BtnExportPdf" Content="PDF"
                            Style="{StaticResource ActionButton}"
                            Click="ExportPdf_Click"/>
                    <Button x:Name="BtnExportWord" Content="Word"
                            Style="{StaticResource ActionButton}"
                            Click="ExportWord_Click"/>
                    <Button x:Name="BtnClose" Content="×"
                            Style="{StaticResource ActionButton}"
                            Click="Close_Click"
                            FontSize="16"/>
                </StackPanel>

                <!-- 左侧: 文档标题 (含 dirty 圆点) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="DirtyDot" Width="8" Height="8"
                             Fill="{DynamicResource Brush.Accent}"
                             Margin="0,0,8,0"
                             Visibility="Collapsed"/>
                    <TextBlock x:Name="TitleLabel"
                               Text="No document"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.Ink}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 内容: 左侧 Outline + 右侧文档主体 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="OutlineCol" Width="240" MinWidth="180" MaxWidth="360"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
            </Grid.ColumnDefinitions>

            <views:Outline Grid.Column="0"/>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource Brush.Line}"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- 文档主体: 顶上是 EditorToolbar (仅 Rich 模式可见), 下面是 ContentHost -->
            <DockPanel Grid.Column="2">
                <views:EditorToolbar x:Name="EditorToolbarHost"
                                     DockPanel.Dock="Top"
                                     Visibility="Collapsed"/>
                <Grid x:Name="ContentHost"/>
            </DockPanel>
        </Grid>

    </Grid>
</UserControl>
