<UserControl x:Class="ITforceMarkdown.Views.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:ITforceMarkdown.Models">

    <Grid Background="{DynamicResource Brush.Sidebar}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 搜索栏 -->
            <RowDefinition Height="*"/>     <!-- workspace 列表 -->
            <RowDefinition Height="Auto"/>  <!-- 状态条 -->
        </Grid.RowDefinitions>

        <!-- ===== 搜索栏 ===== -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource Brush.Line}"
                BorderThickness="0,0,0,1"
                Padding="12,10">
            <Grid>
                <TextBox x:Name="SearchBox"
                         Padding="22,6,6,6"
                         FontSize="12"
                         Foreground="{DynamicResource Brush.Ink}"
                         Background="{DynamicResource Brush.Card}"
                         BorderBrush="{DynamicResource Brush.Line}"
                         TextChanged="SearchBox_TextChanged"/>
                <TextBlock Text="🔍 Search documents"
                           IsHitTestVisible="False"
                           Padding="8,8,0,0"
                           Foreground="{DynamicResource Brush.Placeholder}"
                           FontSize="11"
                           x:Name="SearchPlaceholder"/>
            </Grid>
        </Border>

        <!-- ===== 内容: 搜索结果 OR workspace 列表 ===== -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,4">
            <StackPanel x:Name="ContentHost"/>
        </ScrollViewer>

        <!-- ===== 底部状态条 (workspace 数量) ===== -->
        <Border Grid.Row="2"
                Background="{DynamicResource Brush.SidebarSectionInactive}"
                BorderBrush="{DynamicResource Brush.Line}"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <TextBlock x:Name="StatusLabel"
                       Text=""
                       FontSize="11"
                       Foreground="{DynamicResource Brush.Muted}"/>
        </Border>
    </Grid>
</UserControl>
